{
  "expo": {
    "name": "leafhome2",
    "slug": "leafhome2",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "leafhome2",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.leafhome2.app"
    },
    "android": {
  "adaptiveIcon": {
    "foregroundImage": "./assets/android-icon-foreground.png",
    "backgroundColor": "#fff8f9"
  },
  "package": "com.leafhome2.app",
  "navigationBarColor": "#fff8f9"
},
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
